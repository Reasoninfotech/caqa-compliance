{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  class="audit_services_icon section-{{ section.id }}-padding"
  style="background-color:{{ section.settings.back_color }}"
>
  <div class="page-width">
    <div class="audit_services_sec{% if section.settings.two_column %} two_column_block{% endif %}">
      {%- for block in section.blocks -%}
        <div
          class="audit_services_txt{% if block.settings.bigger_image %} bigger_block{% endif %}{% if block.settings.back_color != blank %} dark_sec{% endif %}"
          {% if block.settings.back_color != blank %}
            style="background-color:{{ block.settings.back_color }}"
          {% endif %}
        >
          <figure>
            <img src="{{ block.settings.icon | img_url : "master" }}">
          </figure>
          <div class="txt_content">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.content }}</p>
            {% if block.settings.text != blank %}
              <p
                class="button_img"
                style="{% if block.settings.back_color != blank %}background-image:url({{ 'button_back.png' | asset_url }});{% else %}background-image:url({{ 'buuton-back.png' | asset_url }});{% endif %}"
              >
                {{ block.settings.text }}
              </p>
            {% endif %}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Audit Sevices Icon",
  "settings": [
    {
      "type":"color",
      "id":"back_color",
      "label":"Background Color"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    },
    {
       "type":"checkbox",
       "id":"two_column",
       "label":"Two Column Block"
    }
  ],
  "blocks": [
      {
      "type": "block",
      "name": "block",
      "settings": [
          {
            "type":"checkbox",
            "id":"bigger_image",
            "label":"Bigger Image"
          },
          {
            "type":"image_picker",
            "id":"icon",
            "label":"Icon"
          },
          {
            "type":"text",
            "id":"title",
            "label":"Title"
          },
          {
            "type":"text",
            "id":"content",
            "label":"Content"
          },
          {
            "type":"text",
            "id":"text",
            "label":"Text"
          },
          {
            "type":"color",
            "id":"back_color",
            "label":"Background Color"
          }
      ]
    }
  ],
  "presets":[
    {
      "name":"Audit Sevices Icon"
    }
  ]
}
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
