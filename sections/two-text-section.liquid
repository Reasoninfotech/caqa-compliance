{% style %}
  #sec__{{ section.id }}{background-color:{{ section.settings.bg_color }};padding:50px 0;}
  .two-text-section .two-text_block_main{display:flex;flex-wrap:wrap;gap:20px;}
  .two-text-section .two-text_block{width:calc(50% - 10px);}
  .two-text-section .two-text_block figure{margin:0;}
  .two-text-section .two-text_block figure img{max-width:100%;}
  .two-text-section .two-text_block h2{font-size:30px;margin:10px 0 0 0;color:#fff;}
  .two-text-section .two-text_block div{font-size:18px;line-height:28px;color:#fff;}
  .two-text-section .two-text_block div p{margin:0;}

  @media screen and (max-width:1200px){
    .two-text-section .two-text_block h2 {font-size: 27px;}
    .two-text-section .two-text_block div {font-size: 17px;line-height: 23px;}
  }

  @media screen and (max-width:768px){
  #sec__{{ section.id }}{padding:30px 0;}
  .two-text-section .two-text_block{width:100%;}  
  }

  @media screen and (max-width:575px){
    .two-text-section .two-text_block h2 {font-size: 24px;}
    .two-text-section .two-text_block div {font-size: 14px;line-height: 20px;}
  }
  
  
{% endstyle %}


<div class="two-text-section" id="sec__{{ section.id }}">
  <div class="page-width">
    <div class="two-text_block_main">
      {% for block in section.blocks %}
          <div class="two-text_block">
              <figure>
                <img src="https://cdn.shopify.com/s/files/1/0619/9531/9474/files/Path.png">
              </figure>
              <h2>{{ block.settings.heading }}</h2>
              <div>{{ block.settings.description }}</div>
          </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "Two Text Section",
    "settings": [
      {
        "type":"color",
        "id":"bg_color",
        "label":"Background Color"
      }
    ],
    "blocks":[
      {
        "name":"Two Text Block",
        "type":"text",
        "settings":[
          {
            "type":"text",
            "id":"heading",
            "label":"Heading"
          },
          {
            "type":"richtext",
            "id":"description",
            "label":"Description"
          }
        ]
      }
    ],
    "presets":[
      {
        "name":"Two Text Section"
      }
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

