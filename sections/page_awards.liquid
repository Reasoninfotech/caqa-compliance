<style>
  .page_awards{padding-top:50px}
  .page_awards .page-width{max-width:1200px;padding:0 15px}
  .page_awards .page_awards_block{display:flex;flex-wrap:wrap;box-shadow:10px 10px 20px 0 rgb(0 0 0 / 50%);border:10px solid #cecece;margin-bottom:50px}
  .page_awards .page_awards_block .image__block{display:flex;width:33.33%;justify-content:center}
  .page_awards .page_awards_block .image__block img{width:100%;height:100%;object-fit:contain}
  .page_awards .page_awards_block .desc__block{width:66.66%;display:flex;flex-direction:column;align-items:flex-start;justify-content:center;padding:50px}
  .page_awards .page_awards_block .desc__block .rte{font-size:25px;line-height:35px}
  .page_awards .page_awards_block .desc__block figure{display:flex;margin}
  .page_awards .page_awards_block .desc__block figure img{max-width:100%;max-height:100%;}
  .page_awards .page_awards_block .desc__block .link{margin-top:1rem;font-weight:600}

  @media screen and (max-width:991px){
    .page_awards .page_awards_block .desc__block .rte{font-size:22px;line-height:30px}
  }
  @media screen and (max-width:768px){
    .page_awards .page-width{max-width:575px;}
    .page_awards .page_awards_block .image__block{width:100%}
    .page_awards .page_awards_block .desc__block{width:100%;padding:20px}
    .page_awards .page_awards_block .desc__block .rte{font-size:18px;line-height:26px}
  }
</style>

{% assign image = section.settings.bread_crumb_back %}
{% if page.metafields.page.bread_crumb_image != blank %}
{% assign image = page.metafields.page.bread_crumb_image %}
{% endif %}
{% render 'bread_crumb' back_img:image, title:section.settings.bread_title %}
<section class="page_awards">
  <div class="page-width">
    {% for block in section.blocks %}
      {% if block.settings.image != blank and block.settings.desc != blank %}
        <div class="page_awards_block">
          <div class="image__block">
            <img src="{{ block.settings.image | img_url:'400x' }}">
          </div>
          <div class="desc__block">
            {% if block.settings.a_image != blank %}
              <figure>
                <img src="{{ block.settings.a_image | img_url:"200x" }}">
              </figure>
            {% endif %}
            <div class="rte">
              {{ block.settings.desc }}
            </div>
            {% if block.settings.btn != blank and block.settings.url != blank %}
                <a href="{{ block.settings.url }}" class="link">{{ block.settings.btn }}</a>
              {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>
{% schema %}
  {
    "name": "Page Awards",
    "settings": [
      {
        "type":"image_picker",
        "id":"bread_crumb_back",
        "label":"Title Background image"
      },
      {
        "type":"text",
        "id":"bread_title",
        "label":"Breadcrumb title"
      }
    ],
    "blocks":[
      {
        "type":"award",
        "name":"award",
        "settings":[
          {
            "type":"image_picker",
            "id":"image",
            "label":"Block Image"
          },
          {
            "type":"image_picker",
            "id":"a_image",
            "label":"award image"
          },
          {
            "type":"textarea",
            "id":"desc",
            "label":"Block Description"
          },
          {
            "type":"text",
            "id":"btn",
            "label":"Block url"
          },
          {
            "type":"url",
            "id":"url",
            "label":"url"
          }
        ]
      }
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}