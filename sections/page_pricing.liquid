{% render 'bread_crumb' back_img:page.metafields.page.bread_crumb_image, title:page.title %}

<style>
  .page_pricing{padding:60px 0}
  .page_pricing .blocks_title{max-width:800px;padding:15px}
  .page_pricing .page-width{max-width:1200px;padding:0 10px}
  .page_pricing .pricing_plans_row{display:flex;flex-wrap:wrap;align-items:flex-start}
  .page_pricing .pricing_plans_row .pricing_plans{width:calc(25% - 30px);padding:32px 20px 42px;margin:15px;display:flex;text-align: center;align-items:center;flex-direction:column;box-shadow:0 11px 35px rgb(0 0 0 / 11%);background-color:#f6f6f6;letter-spacing:0}
  .page_pricing .pricing_plans_row .pricing_plans.blk_green{color:#fff;background-color:#018C0B}
  .page_pricing .pricing_plans_row .pricing_plans .blk_subtitle{font-size:14px;color:#0b57e3;font-weight:600;line-height:30px;display:block!important;min-height:30px}
  .page_pricing .pricing_plans_row .pricing_plans .blk_title{margin-top: 4px;margin-bottom: 8px;font-size: 25px;font-weight:600;;line-height:30px;}
  .page_pricing .pricing_plans_row .pricing_plans .blk_desc{margin-bottom:11px;font-size:16px;color:#666}
  .page_pricing .pricing_plans_row .pricing_plans.blk_green .blk_desc{color:#fff}
  .page_pricing .pricing_plans_row .pricing_plans .blk_price{font-size: 46px;line-height: 1;font-weight: 700;margin-bottom: 17px;}
  .page_pricing .pricing_plans_row .pricing_plans .blk_img{margin-bottom:25px;display: flex;justify-content:center}
  .page_pricing .pricing_plans_row .pricing_plans .blk_img img{height;65px;width:65px;object-fit:contain}
  .page_pricing .pricing_plans_row .pricing_plans .blk_invoice{font-size: 13px;line-height: 22px;}
  .page_pricing .pricing_plans_row .pricing_plans .blk_time{font-size: 18px;font-weight: 700;margin-bottom:20px;line-height:normal}
  .page_pricing .pricing_plans_row .pricing_plans .button:hover{background-color:#fff;color:rgba(var(--color-button),var(--alpha-button-background))}
  
  @media screen and (max-width:1200px){
    .page_pricing .pricing_plans_row .pricing_plans .blk_title{font-size:22px;line-height:26px;}
    .page_pricing .pricing_plans_row .pricing_plans .blk_desc{font-size:15px}
    .page_pricing .pricing_plans_row .pricing_plans .blk_price{font-size: 35px;}
  }
  @media screen and (max-width:991px){
    .page_pricing{padding:30px 0}
    .page_pricing .pricing_plans_row .pricing_plans{width:calc(50% - 30px);}
  }
  @media screen and (max-width:575px){
    .page_pricing .pricing_plans_row .pricing_plans{width:100%;margin:15px 15px 30px}
  }
  
</style>

<div class="page_pricing">
  <div class="page-width">
    {% if section.settings.title != blank %}
    <div class="blocks_title">
      {% if section.settings.subtitle != blank %}<span>{{ section.settings.subtitle }}</span>{% endif %}
      <h1>{{ section.settings.title }}</h1>
    </div>
    {% endif %}
  <div class="pricing_plans_row">
    {% for block in section.blocks %}
    <div class="pricing_plans {% if block.settings.type %}blk_green{% endif %}">
      <div class="blk_subtitle">{{ block.settings.subtitle }}</div>
      {% if block.settings.title != blank %}<div class="blk_title">{{ block.settings.title }}</div>{% endif %}
      {% if block.settings.desc != blank %}<div class="blk_desc">{{ block.settings.desc }}</div>{% endif %}
      {% if block.settings.price != blank %}<div class="blk_price">{{ block.settings.price }}</div>{% endif %}
      {% if block.settings.img != blank %}<div class="blk_img"><img src="{{ block.settings.img | img_url:'100x' }}"></div>{% endif %}
      {% if block.settings.invoice != blank %}<div class="blk_invoice">{{ block.settings.invoice }}</div>{% endif %}
      {% if block.settings.time != blank %}<div class="blk_time">{{ block.settings.time }}</div>{% endif %}
      {% if block.settings.btn != blank and block.settings.url != blank %}<a class="button" href="{{ block.settings.url }}">{{ block.settings.btn }}</a>{% endif %}
    </div>
    {% endfor%}
  </div>
    </div>
</div>
{% schema %}
  {
    "name": "Pricing",
    "settings": [
		{
			"type":"text",
			"id":"title",
			"label":"Title"
		},
		{
			"type":"text",
			"id":"subtitle",
			"label":"Subtitle"
		}
	],
	"blocks":[
		{
			"type":"block",
			"name":"Pricing",
			"settings":[
				{
					"type":"checkbox",
					"id":"type",
					"label":"Block Type Green"
				},
				{
					"type":"text",
					"id":"title",
					"label":"title"
				},
				{
					"type":"text",
					"id":"subtitle",
					"label":"subtitle"
				},
				{
					"type":"text",
					"id":"desc",
					"label":"Description"
				},
				{
					"type":"text",
					"id":"price",
					"label":"Price"
				},
				{
					"type":"image_picker",
					"id":"img",
					"label":"Image"
				},
				{
					"type":"text",
					"id":"invoice",
					"label":"Invoice"
				},
				{
					"type":"text",
					"id":"time",
					"label":"Time"
				},
				{
					"type":"text",
					"id":"btn",
					"label":"Button"
				},
				{
					"type":"url",
					"id":"url",
					"label":"Button url"
				}
			]
		}
	]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
