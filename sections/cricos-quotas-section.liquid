{% style %}
  #sec__{{ section.id }}{background-color:{{ section.settings.bg_color }};padding:50px 0}
  .cricos-quotas-section .cricos-quotas-section-block{display:flex;gap: 20px;}
  .cricos-quotas-section .cricos-quotas-section-des{display:flex;flex-direction:column;gap:10px;}
  .cricos-quotas-section .cricos-quotas-section-block figure{margin:0;flex-shrink:0;}
  .cricos-quotas-section .cricos-quotas-section-block figure img{max-width:100%;}
  .cricos-quotas-section .cricos-quotas-des{font-size: 18px;line-height: 24px;color:#fff;font-weight:200;}
  .cricos-quotas-section .cricos-quotas-des strong{font-size: 31px;line-height: 30px;}
  .cricos-quotas-section .cricos-quotas-heading{color:#ffc400;font-size:31px;}
  .cricos-quotas-section .cricos-quotas-des p{margin:0;}


   @media screen and (max-width:1200px){
    .cricos-quotas-section .cricos-quotas-section-block .cricos-quotas-des {font-size: 17px;line-height: 23px;}
  }

  @media screen and (max-width:768px){
    #sec__{{ section.id }}{padding:30px 0;}
    .cricos-quotas-section .cricos-quotas-section-block .cricos-quotas-des strong {font-size: 22px;line-height: 30px;font-style: italic;}
    .cricos-quotas-section .cricos-quotas-section-block .cricos-quotas-des {font-size: 14px;line-height: 18px;}
    .cricos-quotas-section .cricos-quotas-heading {font-size: 25px;}
  }

  @media screen and (max-width:575px){
    .cricos-quotas-section .cricos-quotas-section-block .cricos-quotas-des {font-size: 14px;line-height: 20px;}
    .cricos-quotas-section .cricos-quotas-heading {font-size: 20px;}
  }
  
{% endstyle %}
  <div class="cricos-quotas-section" id="sec__{{ section.id }}">
  <div class="page-width">
          <div class="cricos-quotas-section-block">
              <figure>
                <img src="https://cdn.shopify.com/s/files/1/0619/9531/9474/files/Path.png">
              </figure>
              <div class="cricos-quotas-section-des">
                <div class="cricos-quotas-des">{{ section.settings.des }}</div>
                <h2 class="cricos-quotas-heading">{{ section.settings.heading }}</h2>
              </div>
          </div>
      </div>
  </div>
</div>
{% schema %}
  {
    "name": "Cricos Section",
    "settings": [
      {
        "type":"color",
        "id":"bg_color",
        "label":"background Color"
      },
      {
        "type":"richtext",
        "id":"des",
        "label":"Description"
      },
      {
        "type":"text",
        "id":"heading",
        "label":"Heading"
      }
    ],
    "presets":[
      {
        "name":"Cricos Section"
      }
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

