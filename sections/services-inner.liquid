            <span>Download Capability Statement</span>
          </a>
        </div>
        {% endif %}
      </div>
    </div>    
  </div>
</section>


{% schema %}
{
"name": "Services Inner Page",
"settings": [
{
"type":"image_picker",
"id":"bread_crumb_back",
"label":"Title Background image"
},
{
"type":"text",
"id":"bread_title",
"label":"Page title"
},
{
"type":"header",
"content":"SideBar"
},
{
"type": "link_list",
"id": "sidemenu",
"label": "SideBar Menu"
},
{
"type":"text",
"id":"contact_title",
"label":"Contact Title"
},
{
"type":"html",
"id":"contact_txt",
"label":"Contact Text"
},
{
"type":"text",
"id":"pdf_link",
"label":"PDF URL"
}
]
}
{% endschema %}

