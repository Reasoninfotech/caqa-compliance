
<style>
{% comment %} .custom-event{position:relative;padding:300px 0 0;margin-top:-360px}
  #custom-event-{{ section.id }}.custom-event::before{content:"";position:absolute;top:0;left:0;background-image:url({{ section.settings.backimg1 | img_url:"master" }});width: 625px;height: 991px;z-index: -1;opacity:0.7;background-repeat:no-repeat;}
.custom-event .sechead{font-size:60px;text-align:center;color:white;margin-bottom:60px;}

#custom-event-{{ section.id }}.custom-event .custom-event-main{background-image:url({{ section.settings.backimg2 | img_url:"master" }});}
.custom-event .custom-event-main {background-repeat:no-repeat;padding:155px 0 220px;}
  .custom-event .custom-event-main .custom-event-main-inner{display:flex;justify-content:center;max-width:1250px;margin:0 auto;padding-left:50px;}
  .custom-event .custom-event-main .custom-event-main-inner .custom-event-media{max-width:500px;margin:0;overflow:hidden;border-radius:20px;}
  .custom-event .custom-event-main .custom-event-main-inner .custom-event-media img{width:100%;height:100%;}
  .custom-event .custom-event-main .custom-event-main-inner .custom-event-content{max-width:700px;padding:20px 0 20px 60px;}
  
.custom-event .custom-event-main a.button{padding: 22px 45px;border-radius: 68px;font-weight: 600;background: #fed615;color: #0052CC;}
  .custom-event .custom-event-main a.button:hover{background: #fff;}

.custom-event .custom-event-main .event-head{font-size:26px;color:#FED615;line-height:normal;}
.custom-event .custom-event-main .event-head strong{font-size:35px;line-height:normal;font-weight:600;}
.custom-event .custom-event-main .event-subhead{font-size:24px;color:white;line-height:normal;margin:0;}
.custom-event .custom-event-main .event-subhead strong{font-weight:600;}
.custom-event .custom-event-main .event-subhead *{margin:0;}

  .custom-event .custom-event-main .event-icon-block{display:flex;background:rgba(0, 82, 204, 1);padding: 18px 18px 18px 28px;border-radius: 15px;width:fit-content;margin:35px 0 25px}
  .custom-event .custom-event-main .event-icon-block .icon-block{max-width:285px;display:flex;align-items:center;text-align:left;}
  .custom-event .custom-event-main .event-icon-block .icon-block img{width:48px;height:48px;}
  .custom-event .custom-event-main .event-icon-block .icon-block span{font-size:20px;color:white;display:block;padding: 0 15px;font-weight: 600;line-height: 25px;}
  
.custom-event .custom-event-main .event-text{font-size: 18px;line-height: normal;color:#a0aed5;}

@media(max-width:1600px){
  .custom-event{padding:200px 0 0;margin-top:-260px}
.custom-event .sechead{font-size:45px;margin-bottom:45px;}
  .custom-event .custom-event-main{padding:120px 0 150px;}
 #custom-event-{{ section.id }}.custom-event .custom-event-main {background-size: cover;background-position: right;}
 .custom-event .custom-event-main .custom-event-main-inner{padding-left:0;}
  .custom-event .custom-event-main .custom-event-main-inner .custom-event-content{padding:20px 0 20px 40px;width:60%;max-width:unset;}
  .custom-event .custom-event-main .custom-event-main-inner .custom-event-media{width:40%;max-width:unset;}
  .custom-event .custom-event-main .event-icon-block{margin:20px 0;}
  .custom-event .custom-event-main .event-icon-block .icon-block img{width:35px;height:35px;}
  .custom-event .custom-event-main a.button{padding:15px 30px}
}

@media(max-width:1200px){
  .custom-event .custom-event-main .event-head{font-size:22px;}
.custom-event .custom-event-main .event-head strong{font-size:26px;}
  .custom-event .custom-event-main .event-subhead{font-size:20px;}
  .custom-event .custom-event-main .event-text{font-size:16px}
  .custom-event .custom-event-main .event-icon-block .icon-block span{font-size:16px;line-height:18px;}
}
@media(max-width:991px){
  
  .custom-event{margin-top:-150px}
  #custom-event-{{ section.id }}.custom-event::before{width:100%;}
  
.custom-event .custom-event-main .custom-event-main-inner{flex-direction:column;max-width:500px;margin:0 auto;}
  .custom-event .custom-event-main .custom-event-main-inner .custom-event-content{padding:20px 0;width:100%;text-align:center;}
  .custom-event .custom-event-main .event-icon-block{margin:20px auto;}
  .custom-event .custom-event-main .custom-event-main-inner .custom-event-media{width:100%}
}
@media(max-width:767px){
  #custom-event-{{ section.id }}.custom-event::before{display:none;}
  .custom-event{margin-top:0px;padding:20px 0;}
  .custom-event .custom-event-main{padding:75px 0;}
.custom-event .sechead{font-size:35px;margin-bottom:35px;}
}
@media(max-width:575px){
.custom-event .custom-event-main .custom-event-main-inner .custom-event-content{text-align:left;}
.custom-event .sechead{font-size:26px;margin-bottom:25px;}
  .custom-event .custom-event-main .event-head{font-size:18px;}
  .custom-event .custom-event-main .event-head strong{font-size:19px;}
  .custom-event .custom-event-main .event-subhead{font-size:16px;line-height:20px;}
  .custom-event .custom-event-main .event-text {font-size: 14px;line-height: 18px;}
  .custom-event .custom-event-main .event-icon-block{flex-direction:column;width:100%;}
  .custom-event .custom-event-main .event-icon-block .icon-block{margin:10px 0;max-width:100%;}
} {% endcomment %}


