
<style>
iframe[Attributes Style] {
    width: 100%;
    height: 100%;
}
.iframe-wrapper {
	height:835px !important;	
	padding-bottom:50px;
}
.iframe-wrapper iframe {
	height:835px !important;
}
@media only screen and (max-width: 1200px) {
	.iframe-wrapper {
	height:1000px !important;	
}
	.iframe-wrapper iframe {
	height:1000px !important;
}
}
@media only screen and (max-width: 991px) {
	.iframe-wrapper {
	height:1100px !important;	
}
	.iframe-wrapper iframe {
	height:1100px !important;
}
}
@media only screen and (max-width: 767px) {
	.iframe-wrapper {
	height:1010px !important;	
}
	.iframe-wrapper iframe {
	height:1010px !important;
}
}

</style>
<script>
document.addEventListener("DOMContentLoaded", function () {
    fetch("https://caqaskills.com.au/wp-json/wp/v2/booking?per_page=100&_embed")
        .then(res => res.json())
        .then(data => {
            if (!Array.isArray(data)) {
                hideIframe();
                return;
            }
            const has67 = data.some(item => 
                item.booking_category &&
                Array.isArray(item.booking_category) &&
                item.booking_category.includes(67)
            );
            if (!has67) {
                hideIframe();
            } else {
                console.log("🟢 Category 67 exists — iframe visible");
            }
        })
        .catch(err => {
            console.error("❌ API fetch error:", err);
            hideIframe();
        });
    function hideIframe() {
        const wrapper = document.querySelector('.iframe-wrapper');
        if (wrapper) {
            wrapper.style.display = 'none';
        }
    }
});
</script>
<div class="iframe-wrapper">
 <iframe src="https://caqaskills.com.au/webinars-slider/?site=https://caqa.com.au/" width="100%" height="100%" style="border: 0;" loading="lazy"></iframe>
</div>
