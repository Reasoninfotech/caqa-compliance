</style>
<script>
document.addEventListener("DOMContentLoaded", function () {
    fetch("https://caqaskills.com.au/wp-json/wp/v2/booking?per_page=100&_embed")
        .then(res => res.json())
        .then(data => {
            if (!Array.isArray(data)) {
                hideIframe();
                return;
            }
            const has67 = data.some(item => 
                item.booking_category &&
                Array.isArray(item.booking_category) &&
                item.booking_category.includes(67)
            );
            if (!has67) {
                hideIframe();
            } else {
                console.log("🟢 Category 67 exists — iframe visible");
            }
        })
        .catch(err => {
            console.error("❌ API fetch error:", err);
            hideIframe();
        });
    function hideIframe() {
        const wrapper = document.querySelector('.iframe-wrapper');
        if (wrapper) {
            wrapper.style.display = 'none';
        }
    }
});
</script>

{% comment %} <section class="custom-event" id="custom-event-{{ section.id }}">



    
<div class="custom-event-main">
  <div class="page-width">
    
    {% if section.settings.head != blank %}
    <h1 class="sechead">{{ section.settings.sechead }}</h1>
    {% endif %}

    <div class="custom-event-main-inner">
<figure class="custom-event-media">
    <img src="{{ section.settings.img | img_url:"master" }}">
</figure>
<div class="custom-event-content">
    {% if section.settings.head != blank %}
    <div class="event-head">{{ section.settings.head }}</div>
    {% endif %}
    {% if section.settings.subhead != blank %}
    <div class="event-subhead">{{ section.settings.subhead }}</div>
    {% endif %}

    {% if section.settings.text != blank %}
    <div class="event-text">{{ section.settings.text }}</div>
    {% endif %}
  
    <div class="event-icon-block">
        {% for block in section.blocks %}
        <div class="icon-block">
            {% if block.settings.icon != blank %}
            <img src="{{ block.settings.icon | img_url:"master" }}">
            {% endif %}
            {% if block.settings.itext != blank %}
            <span>{{ block.settings.itext }}</span>
            {% endif %}
        </div>
        {% endfor %}
    </div>

  {% if section.settings.btn != blank and section.settings.btnurl != blank %}
<div class="custom-event-btn">
<a href="{{ section.settings.btnurl }}" class="button btn_blue">{{ section.settings.btn }}</a>
</div>
{% endif %}

</div>
    


  </div>
</div>
</div>
</section> {% endcomment %}
<div class="iframe-wrapper">
 <iframe src="https://caqaskills.com.au/webinars-slider/?site=https://caqa.com.au/" width="100%" height="100%" style="border: 0;"></iframe>
</div>
