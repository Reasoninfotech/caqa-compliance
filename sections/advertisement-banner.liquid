{%- if section.settings.show_block and section.settings.image != blank -%}
  {% style %}
        #advertisemente_banner{
          position: fixed;
          bottom: 24px;
          right: 24px;
          z-index: 99999;
          transform: translateY(450px);
          transition: all 0.5s;
        }
        #advertisemente_banner.active{
          transform: translateY(0px);
        }
        .esDyHv {
          position: relative;
          width: 100%;
          max-width: 400px;
          margin: 0px;
          padding: 0px;
          line-height: 0;
      }
        .foewEZ.foewEZ.foewEZ {
          max-width: 400px;
          height: auto;
          margin: 0px auto;
          position: relative;
          background-color: transparent;
          box-shadow: rgb(0 0 0 / 30%) 4px 4px 30px;
          pointer-events: all;
          transition: all 0.3s ease-in-out 0s;
      }
        .kgVeSL.kgVeSL.kgVeSL {
          padding: 0px;
          margin: 0px;
          line-height: 0;
          width: 100%;
          height: 100%;
          display: block;
          cursor: pointer;
          opacity: 1;
      }
      .gPwKiB a {
          color: rgb(0, 0, 238);
          text-decoration: underline;
          background-color: transparent;
      }
      .gPwKiB p, .gPwKiB a {
          font-family: var(--font-stack);
          font-size: 16px;
          font-weight: 400;
          line-height: 1.5;
          color: rgb(51, 51, 51);
          text-align: left;
          text-decoration: none;
      }
        .gkiPek.gkiPek.gkiPek {
          max-width: 100%;
          height: auto;
          display: inline;
      }
    .gTyqYG {
        position: absolute;
        top: 0px;
        right: 0px;
        bottom: inherit;
        width: 40px;
        height: 40px;
        border-radius: 20px;
        padding: 3px;
        box-shadow: rgb(0 0 0 / 30%) 2px 2px 5px;
        opacity: 1;
        display: flex;
        transform: translate(50%, -50%);
        place-content: center;
        -webkit-box-align: center;
        align-items: center;
        -webkit-box-pack: center;
        cursor: pointer;
        background: rgb(252, 252, 252);
        pointer-events: all;
    }
    .NMzVC {
        color: rgb(0, 0, 0);
        width: 75%;
        height: 75%;
        max-width: 100%;
        max-height: 100%;
        inset: 0px;
        margin: auto;
        opacity: 1;
        transition: opacity 0.2s ease-in-out 0s;
        pointer-events: all;
    }
    #advertisemente_banner img {
        vertical-align: middle;
        border-style: none;
    }
    #advertisemente_banner img:hover{
        filter: invert(1);
    }

    @media only screen and (max-width: 575px){
      .foewEZ.foewEZ.foewEZ{max-width:280px;}
    }
  {% endstyle %}
  <div id="advertisemente_banner">
    <div class="sc-ezWOiH esDyHv anim-default-appear-done">
      <div class="sc-bZkfAO foewEZ plmw-body">
        <a href="{{ section.settings.url }}" class="sc-kLLXSd kgVeSL imageLink"
          ><img
            src="{{ section.settings.image | img_url : "master" }}"
            width="400"
            height="400"
            alt="plmw-image"
            class="sc-ikZpkk gkiPek"
        ></a>
      </div>
      <div data-component="close-button" class="sc-fEOsli gTyqYG close_add_block">
        <svg
          color="rgb(0,0,0,1)"
          aria-hidden="true"
          focusable="false"
          class="sc-fnykZs NMzVC svg-inline--fa fa-times fa-w-10"
          role="img"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 320 512"
        >
          <path fill="currentColor" d="M193.94 256L296.5 153.44l21.15-21.15c3.12-3.12 3.12-8.19 0-11.31l-22.63-22.63c-3.12-3.12-8.19-3.12-11.31 0L160 222.06 36.29 98.34c-3.12-3.12-8.19-3.12-11.31 0L2.34 120.97c-3.12 3.12-3.12 8.19 0 11.31L126.06 256 2.34 379.71c-3.12 3.12-3.12 8.19 0 11.31l22.63 22.63c3.12 3.12 8.19 3.12 11.31 0L160 289.94 262.56 392.5l21.15 21.15c3.12 3.12 8.19 3.12 11.31 0l22.63-22.63c3.12-3.12 3.12-8.19 0-11.31L193.94 256z"></path>
        </svg>
      </div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-cookie/1.4.1/jquery.cookie.min.js"></script>
  <script>
    $( document ).ready(function() {
        function addblock(){
          $("#advertisemente_banner").addClass("active");
        }
        setTimeout(function() {
          {% if section.settings.show_one_time == true %}
            if ($.cookie('advertisemente_banner') != 'disable') {
              addblock();
            }
            $.cookie('advertisemente_banner', 'disable', {expires: 1, path:'/'});
          {% else %}
            addblock();
          {% endif %}
        }, {{ section.settings.value_first | times : 1000 }});

      {% if section.settings.value_min != blank and section.settings.value_max != blank %}
        function getRndInteger(min, max) {
          console.log((Math.floor(Math.random() * (max - min) ) + min) * 1000);
          return (Math.floor(Math.random() * (max - min) ) + min) * 1000;
        }
        var rendomtime = 30000;
        setInterval(function () {
          rendomtime = getRndInteger({{ section.settings.value_min }}, {{ section.settings.value_max }});
          addblock();
        }, rendomtime);
      {% endif %}

      $(".close_add_block").click(function(){
        {% if section.settings.value_min != blank and section.settings.value_max != blank %}
          rendomtime = getRndInteger({{ section.settings.value_min }}, {{ section.settings.value_max }});
        {% endif %}
        $("#advertisemente_banner").removeClass("active");
      });

    });
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Advertisement Banner",
  "settings": [
    {
      "type":"checkbox",
      "id":"show_block",
      "label":"Show Advertisement",
      "default": true
    },
    {
      "type":"checkbox",
      "id":"show_one_time",
      "label":"Show Advertisement One Time",
      "default": true
    },
    {
      "type":"image_picker",
      "id":"image",
      "label":"Image"
    },
    {
      "type":"url",
      "id":"url",
      "label":"URL"
    },
    {
      "type": "text",
      "id": "value_first",
      "label": "Delay before first message after page load",
      "default": "0",
      "info": "Add integer value in seconds."
     },
     {
       "type": "text",
       "id": "value_min",
       "label": "Minimum Random range in seconds with next product.",
       "default": "10",
       "info": "Add integer value in seconds."
      },
      {
        "type": "text",
        "id": "value_max",
        "label": "Maximum Random range in seconds with next product.",
        "default": "40",
        "info": "Add integer value in seconds."
      }
  ]
}
{% endschema %}

