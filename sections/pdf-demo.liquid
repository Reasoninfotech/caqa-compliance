<section class="custom-banner">
  <div class="page-width">
    <div class="custom-banner__wrapper">
      {% for block in section.blocks %}
        <div class="custom-banner__block">
          {% if block.settings.banner_image != blank %}
            <div class="custom-banner__main-image">
              <img
                src="{{ block.settings.banner_image | image_url: width: 1600 }}"
                alt="{{ block.settings.banner_image.alt | escape }}"
                loading="lazy"
              />
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Banner PDF",
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner Image Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "banner_image",
          "label": "Banner Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Banner PDF",
      "blocks": [
        {
          "type": "banner"
        }
      ]
    }
  ]
}
{% endschema %}

<style>
    .custom-banner__main-image img {
        width: 100%;
    height: 100%;
    }
</style>

