<style>
.case-study{padding-top:50px;overflow:hidden;}
.case-study .sechead{font-size:60px;margin-bottom:45px;text-align:center}
.case-study .case-study-main{padding-bottom:60px;}
.case-study .case-study-main .owl-stage-outer{padding:15px 0;}
.case-study .case-study-main .owl-stage{display:flex;}
.case-study .case-study-main .case-study-block{border-radius: 22px;background-color:white;height:100%;box-shadow:0px 0px 16px 0px #0000000a;overflow:hidden;position:relative}

.case-study .case-study-main .case-study-block figure{margin:0;} 
.case-study .case-study-main .case-study-block figure img{width:100%;height:100%;}
.case-study .case-study-main .case-study-block a{position:absolute;top:0;left:0;width:100%;height:100%}
.case-study .case-study-main .case-study-block .iwt-text{font-size: 22px;padding:25px 30px;font-weight: 600;line-height: 22px;}
.case-study .case-study-main .owl-dots{position:absolute;bottom:0;left:50%;transform:translateX(-50%)}
.case-study .img_text-main{display:flex;padding:70px 70px;position:relative;}
.case-study .img_text-main::before{content: "";position: absolute;top:-190px;width: 200px;left: 0px;height: 545px;background:url({{ section.settings.image1 | img_url:"master" }});background-repeat: no-repeat;z-index:-1;}
.case-study .img_text-main::after{content: "";position: absolute;bottom: 0;width: 345px;right:0px;height: 900px;background:url({{ section.settings.image2 | img_url:"master" }});background-repeat: no-repeat;z-index:-1;}
.case-study .img_text-main figure{margin:0;width:50%;}
.case-study .img_text-main figure img{width:100%;height:100%;}
.case-study .img_text-main-content{width:50%;display: flex;align-items: center;padding: 0 80px 0 75px;max-width: 800px;}
.case-study .img_text-main-content .head{font-size:60px;}
.case-study .img_text-main-content .text{font-size: 18px;line-height: normal;margin-bottom:30px;}
.case-study .img_text-main-content a{padding: 25px 55px;}

@media(max-width:1600px){
.case-study .img_text-main-content{padding:10px 0 0 30px;}
.case-study .img_text-main-content .head{font-size:45px;}
.case-study .img_text-main-content .text{font-size:16px;margin-bottom:20px;}
.case-study .img_text-main-content a{padding:15px 25px;}
}
@media(max-width:1200px){
.case-study .sechead{font-size:45px;margin-bottom:25px;}
  .case-study .case-study-main .case-study-block{border-radius:15px;}
.case-study .case-study-main .case-study-block .iwt-text{font-size:18px;padding:15px;}
.case-study .img_text-main::before{display:none;}
.case-study .img_text-main-content .head{font-size:36px;}
.case-study .img_text-main figure img{object-fit:contain;}
}

@media(max-width:991px){
{% comment %} .case-study{margin-bottom:-250px;} {% endcomment %}
.case-study .sechead{font-size:30px;margin-bottom:10px;}
.case-study .case-study-main .case-study-block .iwt-text{font-size:15px;}        
.case-study .img_text-main{flex-direction:column;padding:70px 70px}
.case-study .img_text-main figure{width:100%;}
.case-study .img_text-main-content{width:100%;padding:20px 0}
}
@media(max-width:749px){
{% comment %} .case-study{margin-bottom:-210px;} {% endcomment %}
.case-study .sechead{font-size:25px;}
.case-study .case-study-main{padding-bottom:35px;}
.case-study .img_text-main{padding:50px 15px;}
.case-study .img_text-main-content{padding:40px 0 20px;}
.case-study .img_text-main::after{width:100%;background-position-x:right;opacity:0.7;background-size:contain;}
}
@media(max-width:575px){
.case-study .img_text-main-content .head{font-size:28px;}
.case-study .img_text-main-content .text{font-size:14px;}
}
.case-study {
    background: #f7f8fa;
    position: relative;
    margin-top: -16px;
}
{% comment %} @media (max-width: 749px) {
    .case-study {
        margin-top: -80px;
    }
} {% endcomment %}
</style>
    
<section class="case-study" id="case-study-{{ section.id }}">
  <div class="page-width">
  {% if section.settings.sechead != blank %}
  <h1 class="sechead">
  {{ section.settings.sechead }}
  </h1>
    {% endif %}
    <div class="case-study-main owl-carousel">
      {% for article in section.settings.blog.articles limit: 8 %}
        <div class="case-study-block">
          <figure>
            <img src="{{ article.image.src | img_url:"master" }}">
          </figure>
          <div class="iwt-text">{{ article.title }}</div>
          <a href="{{ article.url }}"></a>
        </div>
        {% endfor %}
    </div>
  </div>
  <div class="img_text-main">
    <figure>
      <img src="{{ section.settings.img | img_url:"master" }}">
    </figure>
    <div class="img_text-main-content">
      <div class="img_text-main-content-inner">
      {% if section.settings.subhead != blank %}
          <h4 class="subhead">{{ section.settings.subhead }}</h4>
          {% endif %}
          {% if section.settings.head != blank %}
          <h1 class="head">{{ section.settings.head }}</h1>
          {% endif %}
          {% if section.settings.text != blank %}
          <div class="text">{{ section.settings.text }}</div>
          {% endif %}
          {% if section.settings.btn != blank and section.settings.url != blank %}
          <a href="{{ section.settings.url }}" target="_blank" class="button btn_blue">{{ section.settings.btn }}</a>
          {% endif %}
          </div>
    </div>
  </div>
</section>
    
    {% schema %}
    {
      "name": "Case Study",
      "settings": [
           {
              "type":"text",
                "id":"sechead",
                  "label":"Section Heading"
            },
            {
              "type":"blog",
                "id":"blog",
                  "label":"Blog"
            },
            {
              "type":"image_picker",
                "id":"image1",
                  "label":"Side Image1"
            },
            {
              "type":"image_picker",
                "id":"image2",
                  "label":"Side Image2"
            },
            {
              "type":"header",
                "content":"Image with Text"
            },
            {
              "type":"image_picker",
                "id":"img",
                  "label":"Image"
            },
            {
              "type":"text",
                "id":"subhead",
                  "label":"Sub Heading"
            },
            {
              "type":"text",
                "id":"head",
                  "label":"Heading"
            },
            {
              "type":"richtext",
                "id":"text",
                  "label":"Text"
            },
            {
              "type":"text",
                "id":"btn",
                  "label":"Button Label"
            },
            {
              "type":"url",
                "id":"url",
                  "label":"Url to Navigate"
            }
            
      ],
        "presets":[
        {
          "name":"Case Study"
        }
        ]
    }
    {% endschema %}
    
    {% stylesheet %}
    {% endstylesheet %}
    
    {% javascript %}
    {% endjavascript %}